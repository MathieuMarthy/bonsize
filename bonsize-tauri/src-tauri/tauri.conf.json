{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "bonsize-gui",
  "version": "2.0.0",
  "identifier": "com.bonsize.ui",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Bonsize",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "desktopTemplate": "assets/package.desktop.hbs"
      }
    }
  }
}